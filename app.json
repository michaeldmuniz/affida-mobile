{
  "expo": {
    "name": "Affida",
    "slug": "affida",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "affida",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.affida.app",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090F"
      },
      "package": "com.affida.app",
      "versionCode": 3
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#09090F",
          "image": "./assets/splash.png",
          "resizeMode": "contain"
        }
      ],
      "expo-asset",
      [
        "expo-build-properties",
        {
          "ios": {
            "privacyManifests": {
              "NSPrivacyTracking": false,
              "NSPrivacyCollectedDataTypes": [],
              "NSPrivacyAccessedAPITypes": [
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
                  "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
                }
              ]
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e9585754-a837-42e8-86de-3e9e83d28f72"
      }
    },
    "privacyPolicyUrl": "https://affida.money/privacy",
    "termsOfServiceUrl": "https://affida.money/terms"
  }
}
